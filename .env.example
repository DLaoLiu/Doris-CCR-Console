# Host port exposed by Docker Compose.
CCR_CONSOLE_PORT=3100

# Internal app listener. Keep HOST=0.0.0.0 inside Docker.
HOST=0.0.0.0
PORT=3100

# Container paths. docker-compose.yml mounts ./data to /app/data.
DATA_DIR=/app/data
DB_PATH=/app/data/ccr-console.db

# Optional credential encryption secret.
# If empty, the app creates /app/data/secret.key automatically.
# Keep this stable once data has been created, otherwise saved Doris passwords cannot be decrypted.
# CCR_CONSOLE_SECRET=replace-with-a-long-random-string
